{
  "hosting": {
    "site": "konbu-cloud",
    "public": "empty-public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "konbu",
          "region": "asia-northeast1"
        }
      }
    ]
  }
}
