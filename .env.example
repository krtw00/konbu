# Required
DATABASE_URL=postgres://konbu:konbu@localhost:5432/konbu?sslmode=disable
SESSION_SECRET=change-me-to-a-random-string

# Optional
PORT=8080
# DEV_USER=dev@local  # Auto-login as this user (development only)
# OPEN_REGISTRATION=true

# App URL / OAuth
# BASE_URL=https://konbu.example.com
# VITE_API_BASE_URL=https://api.konbu.example.com/api/v1
# VITE_PUBLIC_APP_URL=https://konbu.example.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Sponsor webhooks
# WEBHOOK_SECRET=
# KOFI_TOKEN=

# AI chat
# AI_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# DEFAULT_AI_PROVIDER=openai
# DEFAULT_AI_API_KEY=
# DEFAULT_AI_ENDPOINT=
# DEFAULT_AI_MODEL=

# Attachments (Cloudflare R2 / S3-compatible)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_BUCKET=konbu-attachments
# R2_PUBLIC_URL=

# Docker Compose (prod)
# POSTGRES_PASSWORD=change-me
# KONBU_DOMAIN=konbu.example.com
